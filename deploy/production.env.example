NODE_ENV=production
DATABASE_URL=postgresql://eatspay_user:change-me@127.0.0.1:5432/eatspay
JWT_SECRET=replace-with-a-long-random-secret
EATSPAY_HMAC_SECRET=replace-with-a-different-long-random-secret
ADMIN_ROLLBACK_TOKEN=replace-with-admin-mfa-token
PORT=3000
PGSSL=false
CORS_ORIGIN=https://www.eatspay.co.kr,https://eatspay.co.kr
GH_PAYMENTS_BASE_URL=https://api.ghpayments.kr
GH_PAYMENTS_PAY_KEY=replace-with-gh-pay-key

# Optional: Korean National Tax Service business status API key.
# NTS_SERVICE_KEY=

# Optional: Firebase Cloud Messaging for Android/iOS push notifications.
# Use one of these. FIREBASE_SERVICE_ACCOUNT_JSON is convenient for systemd env files,
# GOOGLE_APPLICATION_CREDENTIALS is convenient when the JSON file is stored on disk.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# GOOGLE_APPLICATION_CREDENTIALS=/etc/eatspay/firebase-service-account.json

# Optional: Web/PWA push notifications. Generate with:
# npm run push:vapid
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_VAPID_SUBJECT=mailto:admin@eatspay.co.kr
