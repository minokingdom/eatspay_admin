NODE_ENV=production
DATABASE_URL=postgresql://eatspay_user:change-me@localhost:5432/eatspay
JWT_SECRET=replace-with-a-long-random-secret
EATSPAY_HMAC_SECRET=replace-with-a-different-long-random-secret
ADMIN_ROLLBACK_TOKEN=replace-with-admin-mfa-token
PGSSL=false
PORT=3000
CORS_ORIGIN=https://eatspay.kr
GH_PAYMENTS_BASE_URL=https://api.ghpayments.kr
GH_PAYMENTS_PAY_KEY=replace-with-gh-pay-key
CARDGORILLA_RANKING_URL=https://api.card-gorilla.com:8080/v1/charts/ranking?card_gb=CRD&limit=100&term=weekly&chart=top100&idx=&idx2=
CARDGORILLA_UPDATE_HOUR_KST=6

# Aligo SMS verification for signup phone authentication.
ALIGO_API_KEY=replace-with-aligo-api-key
ALIGO_USER_ID=replace-with-aligo-user-id
ALIGO_SENDER=15663558

# Optional: Korean National Tax Service business status API key.
# NTS_SERVICE_KEY=
